#!/bin/sh

remote_name="$1"
remote_url="$2"

case "$remote_name:$remote_url" in
  upstream:*|*:https://github.com/blender/blender.git|*:https://projects.blender.org/blender/blender.git|*:git@github.com:blender/blender.git|*:git@projects.blender.org:blender/blender.git)
    printf >&2 "\nBlocked push to official Blender remote (%s %s).\nUse origin/usedesktop BlendGym branches only.\n\n" "$remote_name" "$remote_url"
    exit 1
    ;;
esac

command -v git-lfs >/dev/null 2>&1 || { printf >&2 "\n%s\n\n" "This repository is configured for Git LFS but 'git-lfs' was not found on your path. If you no longer wish to use Git LFS, remove this hook by deleting the 'pre-push' file in the hooks directory (set by 'core.hookspath'; usually '.git/hooks')."; exit 2; }
git lfs pre-push "$@"
